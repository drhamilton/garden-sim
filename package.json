    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "@types/suncalc": "^1.9.2",
    "@types/three": "^0.184.1",
    "suncalc": "^2.0.0",
